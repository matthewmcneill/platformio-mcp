{
  "name": "platformio-mcp-server",
  "version": "2.0.1",
  "description": "A board-agnostic MCP server for PlatformIO embedded development - supports 1000+ boards across 30+ platforms",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "platformio-mcp-server": "build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "platformio",
    "embedded",
    "iot",
    "arduino",
    "esp32",
    "stm32",
    "firmware",
    "embedded-systems",
    "ai"
  ],
  "author": "PlatformIO MCP Server Contributors",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "serialport": "^13.0.0",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/serialport": "^10.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/ui": "^4.1.3",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/platformio-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/platformio-mcp-server/issues"
  },
  "homepage": "https://github.com/yourusername/platformio-mcp-server#readme"
}
